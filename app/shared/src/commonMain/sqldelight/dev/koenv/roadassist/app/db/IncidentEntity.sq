CREATE TABLE IF NOT EXISTS IncidentEntity (
    id          INTEGER NOT NULL PRIMARY KEY,
    userId      INTEGER NOT NULL,
    category    TEXT    NOT NULL,
    description TEXT    NOT NULL,
    latitude    REAL    NOT NULL,
    longitude   REAL    NOT NULL,
    photoUrl    TEXT,
    status      TEXT    NOT NULL,
    notes       TEXT,
    createdAt   TEXT    NOT NULL,
    updatedAt   TEXT    NOT NULL
);

selectAll:
SELECT * FROM IncidentEntity ORDER BY createdAt DESC;

selectById:
SELECT * FROM IncidentEntity WHERE id = ?;

upsert:
INSERT OR REPLACE INTO IncidentEntity
VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?);

deleteAll:
DELETE FROM IncidentEntity;
